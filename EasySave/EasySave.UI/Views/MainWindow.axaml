<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EasySave.UI.ViewModels"
        x:Class="EasySave.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="EasySave 2.0"
        Width="900" Height="600"
        Background="#1e1e2e">

	<Grid RowDefinitions="Auto,*">
		<StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8"
					Background="#181825" Height="50">
			<TextBlock Text="💾 EasySave 3.0"
					   Foreground="#cdd6f4" FontSize="18" FontWeight="Bold"
					   VerticalAlignment="Center" Margin="16,0"/>
			<Button Content="{Binding NavJobs}"
					Command="{Binding ShowJobsCommand}"
					Background="#313244" Foreground="#cdd6f4"
					Padding="16,8" CornerRadius="6"/>
			<Button Content="{Binding NavSettings}"
					Command="{Binding ShowSettingsCommand}"
					Background="#313244" Foreground="#cdd6f4"
					Padding="16,8" CornerRadius="6"/>
		</StackPanel>
		<ContentControl Grid.Row="1" Content="{Binding CurrentView}"/>
	</Grid>
</Window>
