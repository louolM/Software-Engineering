<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EasySave.UI.ViewModels"
             x:Class="EasySave.UI.Views.JobListView"
             x:DataType="vm:JobListViewModel">

	<UserControl.Resources>
		<vm:StatusToPausedConverter x:Key="StatusToPausedConverter"/>
		<vm:StatusToActiveConverter x:Key="StatusToActiveConverter"/>
		<vm:StatusToStoppableConverter x:Key="StatusToStoppableConverter"/>
	</UserControl.Resources>

	<Grid RowDefinitions="Auto,*,Auto,Auto,Auto" Margin="16">

		<!-- Barre d'actions globales -->
		<StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
			<Button Content="{Binding BtnNewJob}"      Command="{Binding ShowCreateFormCommand}"
					Background="#a6e3a1" Foreground="#1e1e2e" Padding="12,6" CornerRadius="6"/>
			<Button Content="{Binding BtnRunSelected}" Command="{Binding RunSelectedCommand}"
					Background="#89b4fa" Foreground="#1e1e2e" Padding="12,6" CornerRadius="6"/>
			<Button Content="{Binding BtnRunAll}"      Command="{Binding RunAllCommand}"
					Background="#74c7ec" Foreground="#1e1e2e" Padding="12,6" CornerRadius="6"/>
			<Button Content="{Binding BtnModify}"      Command="{Binding ModifySelectedCommand}"
					Background="#cba6f7" Foreground="#1e1e2e" Padding="20,6" CornerRadius="6"/>
			<Button Content="{Binding BtnDelete}"      Command="{Binding DeleteSelectedCommand}"
					Background="#f38ba8" Foreground="#1e1e2e" Padding="12,6" CornerRadius="6"/>
			<!-- Contrôles globaux Pause / Resume / Stop -->
			<Button Content="{Binding BtnPauseAll}"  Command="{Binding PauseAllCommand}"
        			Background="#f9e2af" Foreground="#1e1e2e" Padding="12,6" CornerRadius="6"/>
			<Button Content="{Binding BtnResumeAll}" Command="{Binding ResumeAllCommand}"
					Background="#a6e3a1" Foreground="#1e1e2e" Padding="12,6" CornerRadius="6"/>
			<Button Content="{Binding BtnStopAll}"   Command="{Binding StopAllCommand}"
					Background="#f38ba8" Foreground="#1e1e2e" Padding="12,6" CornerRadius="6"/>
			<Button Content="{Binding BtnOpenLogs}"    Command="{Binding OpenLogsCommand}"
					Background="#45475a" Foreground="#cdd6f4" Padding="12,6" CornerRadius="6"/>
		</StackPanel>

		<!-- Liste des jobs + progression en temps réel -->
		<Border Grid.Row="1" Background="#181825" CornerRadius="6"
				BorderBrush="#313244" BorderThickness="1">
			<Grid RowDefinitions="Auto,*">

				<!-- En-tête -->
				<Grid Grid.Row="0" ColumnDefinitions="50,180,110,2*,2*,180,90,80,50"
					  Background="#313244">
					<TextBlock Grid.Column="0" Text="ID" Margin="6,0" Foreground="#a6adc8" FontWeight="Bold"/>
					<TextBlock Grid.Column="1" Text="Name" Margin="6,0"     Foreground="#a6adc8" FontWeight="Bold"/>
					<TextBlock Grid.Column="2" Text="Type" Margin="6,0"     Foreground="#a6adc8" FontWeight="Bold"/>
					<TextBlock Grid.Column="3" Text="Source" Margin="6,0"   Foreground="#a6adc8" FontWeight="Bold"/>
					<TextBlock Grid.Column="4" Text="Target" Margin="6,0"   Foreground="#a6adc8" FontWeight="Bold"/>
					<TextBlock Grid.Column="5" Text="Progress" Margin="6,0" Foreground="#a6adc8" FontWeight="Bold"/>
					<TextBlock Grid.Column="6" Text="Status" Margin="6,0"	Foreground="#a6adc8" FontWeight="Bold"/>
					<TextBlock Grid.Column="7" Text="Controls" Margin="6,0" Foreground="#a6adc8" FontWeight="Bold"/>
					<TextBlock Grid.Column="8" Text="Edit" Margin="6,0"     Foreground="#a6adc8" FontWeight="Bold"/>
				</Grid>

				<!-- Lignes avec progression par job -->
				<ListBox Grid.Row="1"
						 ItemsSource="{Binding JobProgress}"
						 SelectedItem="{Binding SelectedProgressItem}"
						 Background="Transparent">
					<ListBox.ItemTemplate>
						<DataTemplate x:DataType="vm:JobProgressItem">
							<Grid ColumnDefinitions="50,180,110,2*,2*,180,90,90,50" MinHeight="56">

								<TextBlock Grid.Column="0" Text="{Binding JobId}"   Foreground="#cdd6f4" VerticalAlignment="Center"/>
								<TextBlock Grid.Column="1" Text="{Binding JobName}" Foreground="#cdd6f4" VerticalAlignment="Center"/>
								<TextBlock Grid.Column="2" Text="{Binding JobType}" Foreground="#cdd6f4" VerticalAlignment="Center"/>
								<TextBlock Grid.Column="3" Text="{Binding SourcePath}"  Margin="6,0" Foreground="#cdd6f4" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
								<TextBlock Grid.Column="4" Text="{Binding TargetPath}"  Margin="6,0" Foreground="#cdd6f4" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

								<!-- Barre de progression -->
								<StackPanel Grid.Column="5"  Margin="6,0" VerticalAlignment="Center" Spacing="2">
									<ProgressBar Value="{Binding Percent}" Minimum="0" Maximum="100"
												 Height="8" CornerRadius="4"
												 Foreground="#89b4fa" Background="#313244"/>
									<TextBlock Text="{Binding ProgressText}" Foreground="#cdd6f4"
											   FontSize="10" HorizontalAlignment="Center"/>
								</StackPanel>

								<!-- Statut -->
								<TextBlock Grid.Column="6" Text="{Binding Status}"
										   Foreground="#a6adc8" FontSize="11"
										   VerticalAlignment="Center" HorizontalAlignment="Center"/>

								<!-- Boutons Pause / Resume / Stop individuels -->
								<StackPanel Grid.Column="7" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
									<Button Content="⏸" FontSize="10" Padding="4,2" CornerRadius="4"
											Background="#f9e2af" Foreground="#1e1e2e"
											Command="{Binding $parent[ListBox].((vm:JobListViewModel)DataContext).PauseJobCommand}"
											CommandParameter="{Binding JobId}"
											IsEnabled="{Binding Status, Converter={StaticResource StatusToActiveConverter}}"/>
									<Button Content="▶" FontSize="10" Padding="4,2" CornerRadius="4"
											Background="#a6e3a1" Foreground="#1e1e2e"
											Command="{Binding $parent[ListBox].((vm:JobListViewModel)DataContext).ResumeJobCommand}"
											CommandParameter="{Binding JobId}"
											IsEnabled="{Binding Status, Converter={StaticResource StatusToPausedConverter}}"/>
									<Button Content="⏹" FontSize="10" Padding="4,2" CornerRadius="4"
											Background="#f38ba8" Foreground="#1e1e2e"
											Command="{Binding $parent[ListBox].((vm:JobListViewModel)DataContext).StopJobCommand}"
											CommandParameter="{Binding JobId}"
											IsEnabled="{Binding Status, Converter={StaticResource StatusToStoppableConverter}}"/>
								</StackPanel>

								<!-- Bouton Edit par job -->
								<Button Grid.Column="8" Content="✎" FontSize="12" Padding="4,2" CornerRadius="4"
										Background="#cba6f7" Foreground="#1e1e2e"
										Command="{Binding $parent[ListBox].((vm:JobListViewModel)DataContext).ModifyJobCommand}"
										CommandParameter="{Binding JobId}"/>

							</Grid>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>
			</Grid>
		</Border>

		<!-- Formulaire création -->
		<Border Grid.Row="2" IsVisible="{Binding IsFormVisible}"
				Background="#313244" CornerRadius="8" Padding="16" Margin="0,12,0,0">
			<StackPanel Spacing="6">
				<TextBlock Text="{Binding FormTitle}" Foreground="#cdd6f4"
						   FontSize="15" FontWeight="Bold" Margin="0,0,0,4"/>

				<TextBlock Text="{Binding LblName}" Foreground="#a6adc8"/>
				<TextBox Text="{Binding FormName}" Background="#1e1e2e" Foreground="#cdd6f4"/>
				<TextBlock Text="{Binding FormNameError}" Foreground="#f38ba8" FontSize="11"
						   IsVisible="{Binding FormNameError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

				<TextBlock Text="{Binding LblSource}" Foreground="#a6adc8" Margin="0,4,0,0"/>
				<Grid ColumnDefinitions="*,Auto">
					<TextBox Grid.Column="0" Text="{Binding FormSource}"
							 Background="#1e1e2e" Foreground="#cdd6f4"
							 PlaceholderText="C:\path\to\source"/>
					<Button Grid.Column="1" Content="{Binding BtnBrowse}"
							Command="{Binding BrowseSourceCommand}"
							Background="#45475a" Foreground="#cdd6f4"
							Padding="10,6" CornerRadius="6" Margin="6,0,0,0"/>
				</Grid>
				<TextBlock Text="{Binding FormSourceError}" Foreground="#f38ba8" FontSize="11"
						   IsVisible="{Binding FormSourceError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

				<TextBlock Text="{Binding LblTarget}" Foreground="#a6adc8" Margin="0,4,0,0"/>
				<Grid ColumnDefinitions="*,Auto">
					<TextBox Grid.Column="0" Text="{Binding FormTarget}"
							 Background="#1e1e2e" Foreground="#cdd6f4"
							 PlaceholderText="C:\path\to\target"/>
					<Button Grid.Column="1" Content="{Binding BtnBrowse}"
							Command="{Binding BrowseTargetCommand}"
							Background="#45475a" Foreground="#cdd6f4"
							Padding="10,6" CornerRadius="6" Margin="6,0,0,0"/>
				</Grid>
				<TextBlock Text="{Binding FormTargetError}" Foreground="#f38ba8" FontSize="11"
						   IsVisible="{Binding FormTargetError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

				<StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
					<TextBlock Text="{Binding LblDiff}" Foreground="#a6adc8" VerticalAlignment="Center"/>
					<CheckBox IsChecked="{Binding FormIsDifferential}" Foreground="#cdd6f4"/>
				</StackPanel>

				<StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
					<Button Content="{Binding BtnCancel}" Command="{Binding CancelFormCommand}"
							Background="#45475a" Foreground="#cdd6f4" Padding="12,6" CornerRadius="6"/>
					<Button Content="{Binding BtnSave}"   Command="{Binding SaveJobCommand}"
							Background="#a6e3a1" Foreground="#1e1e2e" Padding="12,6" CornerRadius="6"/>
				</StackPanel>
			</StackPanel>
		</Border>

		<!-- Message statut succès -->
		<TextBlock Grid.Row="3" Text="{Binding StatusMessage}"
				   Foreground="#a6e3a1" FontSize="13" Margin="0,8,0,0"
				   IsVisible="{Binding StatusIsError, Converter={x:Static BoolConverters.Not}}"/>

		<!-- Message statut erreur -->
		<TextBlock Grid.Row="3" Text="{Binding StatusMessage}"
				   Foreground="#f38ba8" FontSize="13" Margin="0,8,0,0"
				   IsVisible="{Binding StatusIsError}"/>

	</Grid>
</UserControl>
