    %% ──────────────────────────────
    %% Relations
    %% ──────────────────────────────

    %% EasyLog internals
    Logger ..> LogEntry : creates

    %% BackupJob uses BackupType enum
    BackupJob --> BackupType

    %% Services
    BackupService ..|> IBackupService
    BackupService --> IFileService
    BackupService --> IStateRepository
    BackupService --> Logger
    BackupService ..> BackupState : creates
    BackupService ..> AppSettings : reads

    %% Infrastructure implements Services interfaces
    FileService ..|> IFileService
    StateRepository ..|> IStateRepository
    ConfigRepository ..|> IConfigRepository
    SettingsRepository ..|> ISettingsRepository

    %% Infrastructure internals
    StateRepository --> JsonService
    ConfigRepository --> JsonService

    %% ConsoleApp composition root
    Program ..> ConfigRepository
    Program ..> FileService
    Program ..> Logger
    Program ..> StateRepository
    Program ..> SettingsRepository
    Program ..> BackupService
    Program ..> TranslationService
    Program ..> JobViewModel
    Program ..> JobView

    %% ConsoleApp wiring
    JobView --> JobViewModel
    JobView --> TranslationService
    JobViewModel --> IConfigRepository
    JobViewModel --> IBackupService
    JobViewModel --> ISettingsRepository
    JobViewModel ..> BackupJob : exposes List

    %% UI ViewModels inherit ViewModelBase
    MainWindowViewModel --|> ViewModelBase
    JobListViewModel --|> ViewModelBase
    SettingsViewModel --|> ViewModelBase

    %% MainWindowViewModel composes other VMs
    MainWindowViewModel --> JobListViewModel
    MainWindowViewModel --> SettingsViewModel
    MainWindowViewModel --> IFileService
    MainWindowViewModel --> IStateRepository
    MainWindowViewModel --> ISettingsRepository

    %% JobListViewModel dependencies
    JobListViewModel --> IConfigRepository
    JobListViewModel --> IBackupService
    JobListViewModel --> ISettingsRepository

    %% SettingsViewModel dependencies
    SettingsViewModel --> ISettingsRepository

    %% Views linked to their ViewModels
    MainWindow ..> MainWindowViewModel
    JobListView ..> JobListViewModel
    SettingsView ..> SettingsViewModel

    %% Program_UI composition root
    Program_UI ..> App
    App ..> MainWindowViewModel
    App ..> MainWindow