sequenceDiagram
    participant Prog as Program.cs
    participant AppXaml as App.axaml
    participant App as App.axaml.cs
    participant MWvm as MainWindowViewModel <br/>(associates to MainWindow.axaml)
    participant JLvm as JobListViewModel <br/>(associates to JobListView.axaml)
    participant Svm as SettingsViewModel <br/>(associates to SettingsView.axaml)
    participant Watcher as BusinessSoftwareWatcher
    participant BS as BackupService<br/>(from IBackupService Interface)
    participant FS as FileService<br/>(from IFileService Interface)
    participant SR as StateRepository<br/>(from IStateRepository Interface)
    participant SetR as SettingsRepository<br/>(from ISettingsRepository Interface)
    participant LG as Logger
    participant DL as DockerLogService
    participant FM as FileManager

    Prog->>AppXaml: BuildAvaloniaApp().Configure<App>()
    Prog->>App: StartWithClassicDesktopLifetime()
    App->>AppXaml: Initialize() — AvaloniaXamlLoader.Load(this)
    AppXaml-->>App: XAML loaded (styles, templates)
    App->>MWvm: OnFrameworkInitializationCompleted()<br/>→ new MainWindowViewModel()
    note right of MWvm: Instanciate: FileService, StateRepo,<br/>SettingsRepo, ConfigRepo, TranslationService,<br/> Logger, DockerLogService?, BackupService
    MWvm->>JLvm: new JobListViewModel()
    MWvm->>Svm: new SettingsViewModel()
    note over JLvm: User clicks "Run Selected"/"Run All"

    JLvm->>SetR: settingsRepo.Load()
    SetR-->>JLvm: return AppSettings object

    alt IsBusinessSoftwareActive(string processName) return True
        JLvm-->>JLvm: SetError("jobs blocked") 
        note right of JLvm: Break
    end

    JLvm-->>JLvm: StartWatch(AppSettings setting)

    JLvm->>Watcher: new BusinessSoftwareWatcher(software, controllers)
    JLvm->>Watcher: _watcher.Start()
    note right of Watcher: Monitors every 2s —<br/>ctrl.Pause() if software detected<br/>ctrl.Resume() when software closed

    note over JLvm,BS: Version 3.0 — Parallel execution of jobs

    par foreach job (parallel tasks)
        JLvm->>BS: RunBackupAsync(job, settings, controller)

        BS->>FS: GetAllFiles(sourcePath)
        FS-->>BS: IEnumerable<string> (files directories)
        note right of BS: Priority files sorted first<br/>(OrderByDescending on PriorityExtensions)

        BS->>SR: Save(List<BackupState> state) for state.json

        loop foreach file in files (priority order)
            BS-->>BS: await WaitIfPausedAsync(token)<br/>(polling 100ms while IsPaused)
            alt controller.IsStopped
                note right of BS: break
            end

            opt Differential type && LastWriteTime(source) ≤ LastWriteTime(target)
                BS->>SR: Save(state, remaining--)
                note right of BS: If file up-to-date → next iteration
            end

            opt fileSize > MaxParallelFileSize (KB)
                note right of BS: await _largeCopySlot.WaitAsync(controller.Token)<br/>(SemaphoreSlim — max 1 large file at a time)
            end

            BS->>FS: CopyFile(source, target)


            opt ext ∈ EncryptedExtensions
                note right of BS: await _cryptoSlot.WaitAsync()<br/>(SemaphoreSlim — CryptoSoft is single-instance)
                BS->>BS: RunCryptoSoft(targetFile, key)
                BS->>FM: TransformFile()
                FM-->>BS: ExitCode (encryption duration (ms))

                note right of BS: _cryptoSlot.Release()
            end

            alt success
                BS->>LG: WriteLog(new LogEntry — TransferTime: transferDuration )
                note right of LG: Dispatch per LogDestination setting:<br/>Local or Both → Logger.Write()<br/>Docker or Both → DockerLogService.Send()
                opt LogDestination is "Docker" or "Both"
                    LG->>DL: Send(LogEntry)
                end
            else catch
                BS->>LG: WriteLog(new LogEntry — TransferTime: -1)
                opt LogDestination is "Docker" or "Both"
                    LG->>DL: Send(LogEntry)
                end
            end

            BS->>SR: Save(state, remaining--)
        end

        BS->>SR: Save(BackupState INACTIVE or STOPPED)
        BS-->>JLvm: Task completed
    end

    JLvm->>Watcher: StopWatcher()
    opt RunAll()|StartJob()|<br/>DeleteSelected()
        JLvm-->>JLvm: ShowSuccessAutoHide(...) — Task.Delay(5s)
    end
