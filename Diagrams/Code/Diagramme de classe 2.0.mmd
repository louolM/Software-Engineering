    %% ──────────────────────────────
    %% EasyLog
    %% ──────────────────────────────
    namespace EasyLog {
        class LogEntry {
            +DateTime Timestamp
            +string BackupName
            +string SourcePath
            +string TargetPath
            +long FileSize
            +long TransferTime
            +long EncryptionTime
        }
        class Logger {
            -readonly string _logDirectory
            -readonly string _format
            +void Logger(string format)
            +void Write(LogEntry entry)
            -void WriteJson(LogEntry entry)
            -void WriteXml(LogEntry entry)
        }
    }
    %% ──────────────────────────────
    %% EasySave.Core
    %% ──────────────────────────────
    namespace EasySave.Core {
        class BackupJob {
            +int Id
            +string Name
            +string SourcePath
            +string TargetPath
            +BackupType Type
        }
        class BackupState {
            +string Name
            +DateTime LastActionTime
            +string Status
            +int TotalFiles
            +int RemainingFiles
            +long TotalSize
            +long RemainingSize
            +string CurrentSourceFile
            +string CurrentTargetFile
            +double Progression
        }
        class BackupType {
            <<enumeration>>
            Full
            Differential
        }
        class AppSettings{
            +string BusinessSoftware
            +List~string~ EncryptedExtensions
            +string EncryptionKey
            +string LogFormat
            +string Language
        }
    }
    %% ──────────────────────────────
    %% EasySave.Services
    %% ──────────────────────────────
    namespace EasySave.Services {
        class IBackupService {
            <<interface>>
            +void RunBackup(BackupJob job)
        }
        class IConfigRepository {
            <<interface>>
            +List~BackupJob~ Load()
            +void Save(List~BackupJob~ jobs)
        }
        class IFileService {
            <<interface>>
            +IEnumerable~string~ GetAllFiles(string directory)
            +void CopyFile(string source, string target)
        }
        class IStateRepository {
            <<interface>>
            +void Save(List~BackupState~ states)
        }
        class ISettingsRepository{
	    <<interface>>
            +AppSettings Load()
            +void Save(AppSettings settings)
        }
        class BackupService {
            -readonly IFileService _fileService
            -readonly Logger _logger
            -readonly IStateRepository _stateRepo
            +void BackupService(IFileService fileService, Logger logger, IStateRepository stateRepo)
            +void RunBackup(BackupJob job)
            -string ToUNC(string path)
            -static long RunCryptoSoft(string filePath, string key)
            -static bool IsBusinessSoftwareRunning(string processName)
        }
    }
    %% ──────────────────────────────
    %% EasySave.Infrastructure
    %% ──────────────────────────────
    namespace EasySave.Infrastructure {
        class FileService {
            +IEnumerable~string~ GetAllFiles(string directory)
            +void CopyFile(string source, string target)
        }
        class JsonService {
            +void Write~T~(string path, object data)
            +T Read~T~(string path)
        }
        class StateRepository {
            -readonly JsonService _jsonService
            -const string StatePath
            +void Save(List~BackupState~ states)
        }
        class ConfigRepository {
            -const string ConfigPath
            +List~BackupJob~ Load()
            +void Save(List~BackupJob~ jobs)
        }
        class SettingsRepository {
            -const string SettingsPath
            +AppSettings Load()
            +void Save(AppSettings settings)
        }
    }
    %% ──────────────────────────────
