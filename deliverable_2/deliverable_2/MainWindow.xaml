<Window x:Class="deliverable_2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:deliverable_2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="10">

        <StackPanel>

            <!-- Champ de saisie -->
            <TextBox x:Name="JobNameTextBox"
                     Text="{Binding JobName, UpdateSourceTrigger=PropertyChanged}"
                     Height="30"
                     Margin="0,0,0,10"
                     ToolTip="Nom du job">

                <!-- Menu contextuel -->
                <TextBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Créer un job"
                                  Command="{Binding CreateJobCommand}"/>

                        <MenuItem Header="Voir les jobs"
                                  Command="{Binding ViewJobsCommand}"/>

                        <Separator/>

                        <MenuItem Header="Supprimer un job"
                                  Command="{Binding DeleteJobCommand}"/>
                    </ContextMenu>
                </TextBox.ContextMenu>

            </TextBox>

            <!-- Liste des jobs -->
            <ListBox ItemsSource="{Binding Jobs}"
                     SelectedItem="{Binding SelectedJob}"
                     Height="150"/>

        </StackPanel>

    </Grid>
</Window>
